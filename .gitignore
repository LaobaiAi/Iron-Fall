# ==========================================
# Iron-Fall Project Constitution
# Combined: Python Backend + Unity Frontend
# ==========================================

# --- Python Backend Rules ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# Environments
.env
.venv

# IDE / Editor specific
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Mypy
.mypy_cache/
.dmypy.json
dmypy.json

# PEP 582
__pypackages__/

# === Cursor / AI Specific ===
.cursorrules
.cursor/

# --- Unity Frontend Rules ---
# Unity generated metadata and temporary files
frontend_unity/[Ll]ibrary/
frontend_unity/[Tt]emp/
frontend_unity/[Oo]bj/
frontend_unity/[Bb]uild/
frontend_unity/[Bb]uilds/
frontend_unity/[Ll]ogs/
frontend_unity/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data.
frontend_unity/[Mm]emoryCaptures/

# Recordings can get quite large.
frontend_unity/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# frontend_unity/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
frontend_unity/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
frontend_unity/.vs/

# Gradle cache directory
frontend_unity/.gradle/

# Android build artifacts
frontend_unity/android/

# iOS build artifacts
frontend_unity/ios/

# Asset meta data which can be regenerated
frontend_unity/[Aa]ssets/AssetStoreTools*

# Asset meta data which should NOT be ignored
# If you want to keep these, comment them out or remove them.
# frontend_unity/[Aa]ssets/**/*.meta

# Unity Package Manager specific
frontend_unity/[Pp]ackages/manifest.json
frontend_unity/[Pp]ackages/packages-lock.json

# Local history and backups
frontend_unity/[Aa]ssets/._*
frontend_unity/[Aa]ssets/*~
frontend_unity/[Aa]ssets/#*#
frontend_unity/[Aa]ssets/*/Backups*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Project Specific (Iron-Fall) ---
# Ignore local configuration files that might contain secrets
backend/app/config.local.py
backend/.env

# Ignore calculation outputs (large files)
*.out
*.f3d
*.db
chroma_db/

# Ignore logs
logs/
*.log
