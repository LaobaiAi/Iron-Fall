# Iron-Fall .gitignore
# 严格遵守项目宪法：严禁提交编译缓存和虚拟环境

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 测试
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# 编译输出
*.out
*.f3d
*.log

# Unity (仅跟踪配置，不跟踪缓存)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# OS
.DS_Store
Thumbs.db

# 个人文档
docs/notes/
*.csv
*.xlsx
*.db
*.sqlite

# 环境变量
.env
.env.local

# Node (如果有前端)
node_modules/
package-lock.json
yarn.lock
